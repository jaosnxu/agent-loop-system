{
  "enabled": false,
  "activeProvider": "codex",
  "command": "codex",
  "model": "",
  "approvalPolicy": "never",
  "timeoutMs": 300000,
  "promptMaxChars": 24000,
  "outputDir": "logs/codex",
  "providerByRole": {
    "triage": "codex",
    "development": "codex",
    "prototyper": "codex",
    "tester": "codex",
    "review": "claude",
    "scoring": "claude"
  },
  "providers": {
    "codex": {
      "type": "codex-exec",
      "command": "codex",
      "enabled": true,
      "versionArgs": ["--version"],
      "model": "",
      "args": ["--ephemeral", "--ignore-rules"],
      "timeoutMs": 300000,
      "notes": "Default local provider. Uses `codex exec` with role sandboxing."
    },
    "claude": {
      "type": "generic-stdin",
      "command": "claude",
      "enabled": true,
      "verified": true,
      "versionArgs": ["--version"],
      "args": ["--print", "--output-format", "text", "--max-budget-usd", "0.10"],
      "timeoutMs": 120000,
      "notes": "Verified local provider for review/scoring. Uses Claude Code non-interactive print mode."
    },
    "opencode": {
      "type": "generic-stdin",
      "command": "opencode",
      "enabled": false,
      "versionArgs": ["--version"],
      "args": [],
      "notes": "Reserved provider slot. Enable only after local OpenCode CLI is installed and command args are verified."
    },
    "gemini": {
      "type": "generic-stdin",
      "command": "gemini",
      "enabled": false,
      "versionArgs": ["--version"],
      "args": [],
      "notes": "Reserved provider slot. Enable only after local Gemini CLI is installed and command args are verified."
    }
  },
  "sandboxByRole": {
    "triage": "read-only",
    "development": "workspace-write",
    "prototyper": "workspace-write",
    "tester": "workspace-write",
    "review": "read-only",
    "scoring": "read-only"
  }
}
